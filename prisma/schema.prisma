generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime     @default(now())
  accounts      Account[]
  sessions      Session[]
  invitations   Invitation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invitation {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  title           String
  slug            String   @unique
  templateId      String
  header          Json     @default("{}")
  eventInfo       Json     @default("{}")
  mainText        Json     @default("{}")
  gallery         Json     @default("{}")
  rsvp            Json     @default("{}")
  footer          Json     @default("{}")
  theme           Json     @default("{}")
  enabledSections String[] @default(["header","eventInfo","mainText","rsvp","footer"])
  sectionOrder    String[] @default(["header","eventInfo","mainText","gallery","rsvp","footer"])
  status          String   @default("draft")
  publishedUrl    String?
  viewCount       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([slug])
}
